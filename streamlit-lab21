import streamlit as st
import numpy as np
import matplotlib.pyplot as plt

# Конфігурація сторінки
st.set_page_config(page_title="Data Lab 21", layout="wide")

def generate_visuals():
    st.title("📈 Система візуального аналізу даних")
    
    # Інструменти керування у бічній панелі
    with st.sidebar:
        st.subheader("Налаштування параметрів")
        model_type = st.radio("Оберіть модель:", ["Синус", "Косинус", "Експонента"])
        scale = st.slider("Масштабування", 0.5, 5.0, 1.0)
        density = st.select_slider("Щільність точок", options=[100, 200, 500, 1000])
        color_theme = st.color_picker("Колір ліній", "#1f77b4")

    # Обчислення
    t = np.linspace(0, 10, density)
    if model_type == "Синус":
        vals = np.sin(t * scale)
    elif model_type == "Косинус":
        vals = np.cos(t * scale)
    else:
        vals = np.exp(t * 0.1 * scale)

    # Побудова графіка
    fig, ax = plt.subplots(figsize=(10, 5))
    ax.plot(t, vals, color=color_theme, lw=2)
    ax.set_title(f"Візуалізація: {model_type}")
    ax.grid(True, alpha=0.4)

    # Розміщення елементів
    l_col, r_col = st.columns([2, 1])
    
    with l_col:
        st.pyplot(fig)
    
    with r_col:
        st.metric("Максимальне значення", round(float(np.max(vals)), 3))
        st.metric("Мінімальне значення", round(float(np.min(vals)), 3))
        
    st.divider()
    
    # Взаємодія з користувачем
    feedback = st.text_input("Додати примітку до результатів:")
    if st.button("Зберегти аналіз"):
        st.success(f"Нотатку '{feedback}' додано до логу.")

if __name__ == "__main__":
    generate_visuals()
